# ============================================
# 🔐 JWT SECRETS ❌ DO WYGENEROWANIA
# ============================================
# KRYTYCZNE! Wygeneruj nowe klucze:
# PowerShell: [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }) -as [byte[]])
# lub: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET="WYGENERUJ_NOWY_KLUCZ_64_ZNAKI_LUB_WIECEJ"
JWT_REFRESH_SECRET="WYGENERUJ_INNY_KLUCZ_64_ZNAKI_LUB_WIECEJ"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

