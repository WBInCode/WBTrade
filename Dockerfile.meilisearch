FROM getmeili/meilisearch:v1.12

# Expose default port
EXPOSE 7700

# Meilisearch config
ENV MEILI_DATA_DIR=/data.ms
ENV MEILI_ENV=production
ENV MEILI_NO_ANALYTICS=true

# Render sets PORT env at runtime - use shell form so variable is resolved at runtime
CMD /bin/sh -c "meilisearch --http-addr 0.0.0.0:${PORT:-7700}"
